generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String?    @map("password_hash")
  firstName    String     @map("first_name")
  lastName     String     @map("last_name")
  avatarUrl    String?    @map("avatar_url")
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  organization    Organization?   @relation("OrgOwner")
  projectsCreated Project[]       @relation("ProjectCreator")
  members         ProjectMember[]
  filesUploaded   File[]
  toursCreated    VirtualTour[]
  accessCodes     AccessCode[]
  refreshTokens   RefreshToken[]

  krpanoTours  KrpanoTour[]
  cadAnnotations CadAnnotation[]
  @@map("users")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model Organization {
  id               String    @id @default(uuid())
  name             String
  ownerId          String    @unique @map("owner_id")
  plan             PlanType  @default(TRIAL)
  planExpiresAt    DateTime? @map("plan_expires_at")
  storageUsedBytes BigInt    @default(0) @map("storage_used_bytes")
  stripeCustomerId String?   @map("stripe_customer_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  owner    User      @relation("OrgOwner", fields: [ownerId], references: [id])
  projects Project[]
  roles    Role[]

  @@map("organizations")
}

enum PlanType {
  TRIAL
  STARTER
  PRO
  ENTERPRISE
}

model Role {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  description    String?
  isSystem       Boolean  @default(false) @map("is_system")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization    @relation(fields: [organizationId], references: [id])
  members      ProjectMember[]

  @@unique([organizationId, name])
  @@map("roles")
}

model Project {
  id             String        @id @default(uuid())
  organizationId String        @map("organization_id")
  name           String
  description    String?
  structureType  StructureType @default(BUILDING) @map("structure_type")
  sector         String?
  coverUrl       String?       @map("cover_url")
  uploadRules    Json?         @map("upload_rules")
  status         ProjectStatus @default(ACTIVE)
  createdById    String        @map("created_by_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  organization Organization           @relation(fields: [organizationId], references: [id])
  createdBy    User                   @relation("ProjectCreator", fields: [createdById], references: [id])
  members      ProjectMember[]
  nodes        ProjectStructureNode[]
  files        File[]
  tours        VirtualTour[]
  accessCodes  AccessCode[]

  krpanoTours  KrpanoTour[]
  @@map("projects")
}

enum StructureType {
  BUILDING
  FREE
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

model ProjectStructureNode {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  parentId  String?  @map("parent_id")
  name      String
  nodeType  String   @default("custom") @map("node_type")
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project  Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   ProjectStructureNode?  @relation("NodeChildren", fields: [parentId], references: [id])
  children ProjectStructureNode[] @relation("NodeChildren")
  files    File[]
  tours    VirtualTour[]

  krpanoTours  KrpanoTour[]
  @@map("project_structure_nodes")
}

model ProjectMember {
  id               String    @id @default(uuid())
  projectId        String    @map("project_id")
  userId           String    @map("user_id")
  roleId           String    @map("role_id")
  canView          Boolean   @default(true) @map("can_view")
  canUpload        Boolean   @default(false) @map("can_upload")
  canDownload      Boolean   @default(true) @map("can_download")
  canShare         Boolean   @default(false) @map("can_share")
  allowedNodeIds   String[]  @map("allowed_node_ids")
  allowedFileIds   String[]  @map("allowed_file_ids")
  expiresAt        DateTime? @map("expires_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  role    Role    @relation(fields: [roleId], references: [id])

  @@unique([projectId, userId])
  @@map("project_members")
}

model File {
  id         String     @id @default(uuid())
  projectId  String     @map("project_id")
  nodeId     String?    @map("node_id")
  uploaderId String     @map("uploader_id")
  name       String
  fileType   FileType   @map("file_type")
  mimeType   String     @map("mime_type")
  storageKey String     @map("storage_key")
  sizeBytes  BigInt     @map("size_bytes")
  status     FileStatus @default(ACTIVE)
  metadata   Json?
  isFavorite Boolean    @default(false) @map("is_favorite")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  deletedAt  DateTime?  @map("deleted_at")

  project  Project               @relation(fields: [projectId], references: [id])
  node     ProjectStructureNode? @relation(fields: [nodeId], references: [id])
  annotations CadAnnotation[]
  uploader User                  @relation(fields: [uploaderId], references: [id])

  @@map("files")
}

enum FileType {
  IMAGE
  IMAGE_360
  PDF
  DWG
  DXF
  OBJ
  GLB
  GLTF
  IFC
  VIDEO
  OTHER
}

enum FileStatus {
  PROCESSING
  ACTIVE
  DELETED
}

model VirtualTour {
  id          String     @id @default(uuid())
  projectId   String     @map("project_id")
  nodeId      String?    @map("node_id")
  name        String
  status      TourStatus @default(DRAFT)
  publishedAt DateTime?  @map("published_at")
  createdById String     @map("created_by_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  project Project               @relation(fields: [projectId], references: [id])
  node    ProjectStructureNode? @relation(fields: [nodeId], references: [id])
  createdBy User                @relation(fields: [createdById], references: [id])
  scenes  TourScene[]

  @@map("virtual_tours")
}

enum TourStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model TourScene {
  id        String   @id @default(uuid())
  tourId    String   @map("tour_id")
  name      String
  position  Int      @default(0)
  isInitial Boolean  @default(false) @map("is_initial")
  imageUrl  String   @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")

  tour     VirtualTour   @relation(fields: [tourId], references: [id], onDelete: Cascade)
  hotspots TourHotspot[]

  @@map("tour_scenes")
}

model TourHotspot {
  id            String      @id @default(uuid())
  sceneId       String      @map("scene_id")
  type          HotspotType
  positionYaw   Float       @map("position_yaw")
  positionPitch Float       @map("position_pitch")
  targetSceneId String?     @map("target_scene_id")
  content       Json
  createdAt     DateTime    @default(now()) @map("created_at")

  scene TourScene @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@map("tour_hotspots")
}

enum HotspotType {
  LINK
  TEXT
  IMAGE
  VIDEO
}

model AccessCode {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  code        String    @unique
  displayCode String    @map("display_code")
  createdById String    @map("created_by_id")
  expiresAt   DateTime? @map("expires_at")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  project   Project     @relation(fields: [projectId], references: [id])
  createdBy User        @relation(fields: [createdById], references: [id])
  shareRule ShareRule?
  accessLogs AccessLog[]

  @@map("access_codes")
}

model ShareRule {
  id               String     @id @default(uuid())
  accessCodeId     String     @unique @map("access_code_id")
  canView          Boolean    @default(true) @map("can_view")
  canDownload      Boolean    @default(false) @map("can_download")
  canUpload        Boolean    @default(false) @map("can_upload")
  canShare         Boolean    @default(false) @map("can_share")
  allowedFileTypes FileType[] @map("allowed_file_types")
  allowedNodeIds   String[]   @map("allowed_node_ids")
  allowedFileIds   String[]   @map("allowed_file_ids")
  createdAt        DateTime   @default(now()) @map("created_at")

  accessCode AccessCode @relation(fields: [accessCodeId], references: [id], onDelete: Cascade)

  @@map("share_rules")
}

model AccessLog {
  id           String   @id @default(uuid())
  accessCodeId String   @map("access_code_id")
  ipAddress    String?  @map("ip_address")
  accessedAt   DateTime @default(now()) @map("accessed_at")

  accessCode AccessCode @relation(fields: [accessCodeId], references: [id])

  @@map("access_logs")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Subscription {
  id                   String             @id @default(uuid())
  organizationId       String             @unique @map("organization_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  plan                 PlanType
  status               SubscriptionStatus
  currentPeriodEnd     DateTime           @map("current_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  @@map("subscriptions")
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

// Visite virtuelle krpano/Pano2VR uploadée sous forme d'archive ZIP,
// décompressée et stockée sur R2. Le champ entryKey pointe vers le fichier
// HTML d'entrée (tour.html) à charger dans une iframe via URL signée.
model KrpanoTour {
  id           String           @id @default(uuid())
  projectId    String           @map("project_id")
  nodeId       String?          @map("node_id")
  uploadedBy   String           @map("uploaded_by")

  name         String
  description  String?
  status       KrpanoTourStatus @default(PROCESSING)

  // Préfixe R2 commun à tous les fichiers extraits (ex: projects/<pid>/krpano/<uuid>/)
  storagePrefix String          @map("storage_prefix")
  // Clé R2 du fichier HTML d'entrée (ex: <prefix>tour.html)
  entryKey      String          @map("entry_key")
  // Clé R2 de la vignette du tour (preview) si détectée
  thumbKey      String?         @map("thumb_key")

  fileCount    Int             @default(0) @map("file_count")
  totalSize    BigInt          @default(0) @map("total_size")
  sceneCount   Int             @default(0) @map("scene_count")

  // Panoramas équirectangulaires extraits pour rejeu Pannellum (JSON array)
  pannellumScenes Json?        @map("pannellum_scenes")

  metadata     Json?

  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  deletedAt    DateTime?       @map("deleted_at")

  project      Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  node         ProjectStructureNode? @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  uploader     User                 @relation(fields: [uploadedBy], references: [id])

  @@index([projectId])
  @@index([nodeId])
  @@map("krpano_tours")
}

enum KrpanoTourStatus {
  PROCESSING
  READY
  ERROR
}

// Annotations posées sur un fichier CAO (DWG/DXF), en coordonnées MONDE du
// dessin (indépendantes du zoom). type: 'marker' (épingle + texte).
model CadAnnotation {
  id        String   @id @default(uuid())
  fileId    String   @map("file_id")
  authorId  String   @map("author_id")
  type      String   @default("marker")
  x         Float
  y         Float
  text      String
  color     String   @default("#EF4444")
  createdAt DateTime @default(now()) @map("created_at")

  file   File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([fileId])
  @@map("cad_annotations")
}

